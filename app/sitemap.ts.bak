import type { MetadataRoute } from 'next';

const BASE = 'https://menace.gguidehub.com';

// 该文件由 scripts/sync-sitemaps.py 自动生成，新增页面后重新运行脚本即可
const ROUTES = [
    '',
    '/about',
    '/advanced-tactics',
    '/beginners-guide',
    '/best-team-comps',
    '/black-market',
    '/black-market-economy',
    '/builds',
    '/campaign-guide',
    '/combat',
    '/factions',
    '/faq',
    '/mission-difficulty-guide',
    '/missions',
    '/morale-discipline-guide',
    '/news',
    '/oci-upgrades',
    '/privacy',
    '/research-priority',
    '/resources',
    '/squad-composition-guide',
    '/squad-leaders',
    '/squad-tier-list',
    '/tactics',
    '/terms',
    '/unit-guide',
    '/vehicles',
    '/weapons',
];

export default function sitemap(): MetadataRoute.Sitemap {
  const now = new Date();
  return ROUTES.map((path) => ({
    url: `${BASE}${path}`,
    lastModified: now,
    changeFrequency: path === '' ? ('daily' as const) : ('weekly' as const),
    priority: path === '' ? 1 : ['privacy', 'terms', 'about'].includes(path.slice(1)) ? 0.3 : 0.7,
  }));
}
